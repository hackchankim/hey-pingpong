# Supabase 환경변수 템플릿
#
# 사용법:
#   1) 복사:  cp .env.example .env.local   (또는 scripts/setup.sh 실행)
#   2) 아래 값을 Supabase 프로젝트 값으로 채운다. (.env.local 은 git 에 커밋되지 않음)
#
# 두 값 모두 Supabase 대시보드 → 프로젝트 → Settings → API 에서 확인.
# 기존 anon 키와 새로운 publishable 키 형식 모두 사용 가능.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
