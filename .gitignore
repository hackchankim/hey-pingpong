# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env

# 자율 개발 에이전트 팀 카카오 시크릿 (명시적 방어선, .env*.local 로도 무시됨)
.env.autodev.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

#shrimp
/shrimp_data/
/shrimp_data/*

#supabase
supabase/.temp/