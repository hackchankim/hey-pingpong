# 자율 개발 에이전트 팀 — 카카오 알림 시크릿 템플릿
#
# 사용법:
#   1) 이 파일을 복사한다:  cp .env.autodev.example .env.autodev.local
#   2) 아래 값을 실제 발급값으로 채운다. (.env.autodev.local 은 git 에 커밋되지 않음)
#
# 카카오 토큰 발급 절차 (최초 1회, 수동):
#   1) 카카오 디벨로퍼스(https://developers.kakao.com) 에서 애플리케이션 생성
#   2) [앱 키] → REST API 키를 KAKAO_REST_API_KEY 에 입력
#   3) [카카오 로그인] 활성화 + [동의항목]에서 "카카오톡 메시지 전송(talk_message)" 사용 설정
#   4) 카카오 로그인 인가코드 → 토큰 발급 과정을 거쳐 refresh_token / access_token 획득
#      (브라우저 동의가 필요한 단계는 세션에서 `! <command>` 로 직접 실행)
#   5) 발급받은 값을 KAKAO_REFRESH_TOKEN / KAKAO_ACCESS_TOKEN 에 입력
#
# 주의: 이 파일(.example)에는 절대 실제 토큰을 넣지 않는다. 실제 값은 .env.autodev.local 에만 둔다.

# REST API 키 (앱 키 화면)
KAKAO_REST_API_KEY=

# 클라이언트 시크릿 (선택) — 앱에서 "Client Secret"을 활성화한 경우에만 필요.
# 미설정 상태에서 시크릿이 필요한 앱이면 토큰 발급/갱신 시 KOE010 오류가 발생한다.
KAKAO_CLIENT_SECRET=

# 리다이렉트 URI — 최초 토큰 발급(issue-token.mjs)에만 사용.
# 카카오 로그인에 등록한 값과 정확히 일치해야 한다. 예: https://localhost:3000/oauth
KAKAO_REDIRECT_URI=

# 리프레시 토큰 — 액세스 토큰 자동 갱신에 사용 (장기 유효)
KAKAO_REFRESH_TOKEN=

# 액세스 토큰 — 발송에 사용 (수명 ~12h, 만료 시 refresh 로 자동 갱신됨)
KAKAO_ACCESS_TOKEN=
